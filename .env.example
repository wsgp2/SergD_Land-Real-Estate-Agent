# --- Anthropic Claude API ---
# Получить ключ: https://console.anthropic.com/settings/keys
# Из РФ нужен прокси (api.anthropic.com отвечает 403 на RU IP).
# См. раздел "Прокси для Anthropic" в README.md.
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Прокси для Anthropic (опционально, нужен в РФ) ---
# Пример для локального xray VLESS-Reality SOCKS5:
# HTTPS_PROXY=socks5h://127.0.0.1:1080
# ALL_PROXY=socks5h://127.0.0.1:1080

# --- DaData (геокодинг для РФ — лучший на СНТ/ДНП/КП) ---
# Получить ключи: https://dadata.ru/registration/  → 10k запросов/день бесплатно
DADATA_API_KEY=
DADATA_SECRET_KEY=

# --- Yandex Geocoder (опционально, fallback) ---
# https://developer.tech.yandex.ru/services → подключить "JavaScript API и HTTP Геокодер"
# 25k запросов/день бесплатно. У нас в тестах ключ 403'ил (возможно нужна активация),
# поэтому в проекте по умолчанию используется DaData.
YANDEX_GEOCODER_KEY=
